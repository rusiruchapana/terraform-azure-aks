# Capstone platform Terraform environment.
#
# This file is an example only.
# Copy it to terraform.tfvars when you are ready to provision the final project cluster.
#
# This Terraform environment provisions one shared AKS platform for the capstone project.
# Inside that cluster, the application will be promoted through Kubernetes namespaces:
#
#   capstone-dev
#   capstone-qa
#   capstone-prod
#
# In a real enterprise setup, dev, qa, and prod may use separate clusters,
# subscriptions, or landing zones. This capstone uses one cluster to keep cost lower.

resource_group_name = "rg-aks-capstone-ae-001"
location            = "australiaeast"

vnet_name                   = "vnet-aks-capstone-ae-001"
vnet_address_space          = ["10.50.0.0/16"]
aks_subnet_name             = "snet-aks-capstone-ae-001"
aks_subnet_address_prefixes = ["10.50.0.0/23"]

enable_nat_gateway                  = true
nat_gateway_name                    = "ngw-aks-capstone-ae-001"
nat_gateway_public_ip_name          = "pip-ngw-aks-capstone-ae-001"
nat_gateway_idle_timeout_in_minutes = 4

aks_identity_name = "id-aks-capstone-ae-001"

aks_cluster_name            = "aks-capstone-ae-001"
aks_dns_prefix              = "aks-capstone-ae-001"
aks_kubernetes_version      = null
aks_private_cluster_enabled = false

aks_oidc_issuer_enabled       = true
aks_workload_identity_enabled = true

system_node_pool_name                    = "system"
system_node_vm_size                      = "Standard_D2s_v5"
system_node_min_count                    = 1
system_node_max_count                    = 2
system_node_os_disk_size_gb              = 64
system_node_only_critical_addons_enabled = true
system_node_temporary_name_for_rotation  = "syspooltmp"

# Start with D2s_v5 to reduce cost and avoid quota issues.
# If the capstone load test needs more capacity, change user_node_vm_size to Standard_D4s_v5.
user_node_pool_name       = "user"
user_node_vm_size         = "Standard_D2s_v5"
user_node_min_count       = 1
user_node_max_count       = 2
user_node_os_disk_size_gb = 128

user_node_labels = {
  workload = "capstone"
  pool     = "user"
}

enable_acr        = true
acr_name          = "replacewithuniquecapstoneacr001"
acr_sku           = "Basic"
acr_admin_enabled = false

enable_keyvault = true
keyvault_name   = "replace-unique-capstone-kv"

keyvault_sku_name                      = "standard"
keyvault_soft_delete_retention_days    = 7
keyvault_purge_protection_enabled      = false
keyvault_public_network_access_enabled = true

# This creates the managed identity and federated identity credential used by
# the capstone app to read secrets from Key Vault.
enable_workload_identity_keyvault_access = true

app_workload_identity_name             = "id-capstone-app-kv-ae-001"
app_workload_namespace                 = "capstone-prod"
app_workload_service_account_name      = "capstone-api-sa"
app_federated_identity_credential_name = "fic-capstone-api-kv-ae"

tags = {
  environment = "capstone-platform"
  project     = "aks-platform-capstone"
  managed_by  = "terraform"
}

# Additional apps workload node pool.
# This is useful for running the capstone application workloads separately from platform/system workloads.
# In Azure Free Trial, 4 vCPU quota may not be enough for the full capstone.
# Recommended: upgrade to Pay-As-You-Go with budget guardrails before enabling the full workload.
enable_apps_node_pool     = true
apps_node_pool_name       = "apps"
apps_node_vm_size         = "Standard_D2_v4"
apps_node_min_count       = 1
apps_node_max_count       = 2
apps_node_os_disk_size_gb = 128

apps_node_labels = {
  workload = "apps"
  project  = "aks-capstone"
}
